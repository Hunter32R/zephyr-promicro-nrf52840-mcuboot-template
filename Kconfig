mainmenu "Promicro double-reset configs"


config DOUBLE_RESET_WINDOW_MS
	int "Double reset detection window in milliseconds"
	default 2000
	range 500 10000
	help
	  Time window in milliseconds to detect a double reset.


config DFU_LED_BLINK_PERIOD_MS
	int "LED blink period during DFU mode in milliseconds"
	default 100
	range 50 1000
	help
	  LED blink half-period in milliseconds during DFU mode.
	  Total blink period will be 2x this value.
	  Default 100ms = 5Hz blink rate (200ms total period).

config MAIN_WRAPPER_DELAY_MS
	int "Delay before calling real main() in milliseconds"
	default 12000
	range 0 60000
	help
	  Time to wait before calling the real main() function when using
	  the main wrapper. This allows the reset detection system to
	  complete its initialization and potentially enter DFU mode
	  before starting the main application logic.

source "Kconfig.zephyr"
